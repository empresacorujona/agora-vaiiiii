<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hospitais Próximos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="static/dash.css">
    <style>
        body { background-color: #f4f6f9; }
        .header { background: linear-gradient(135deg, #00FF00, #00FF00); color: white; padding: 30px; border-radius: 15px; margin-bottom: 25px; }
        .hospital-card { transition: 0.3s; }
        .hospital-card:hover { transform: translateY(-5px); }
        .hospital-icon { font-size: 40px; }
        .footer { margin-top: 40px; text-align: center; color: gray; }
    </style>
</head>
<body>

<div class="container-fluid px-0">

    <nav class="navbar-owl">
        <div class="container d-flex align-items-center justify-content-between py-3">
            <img src="static/logo.png" alt="Owl Convenial" height="52">
            <span class="navbar-tagline">Sempre Perto de Você</span>
        </div>
    </nav>

    <div class="container py-5">

        <div class="page-header mb-4">
            <div>
                <h2 class="page-title">Rede Credenciada</h2>
                <p class="page-subtitle">Hospitais encontrados próximos à sua localização</p>
            </div>
            {% if hospitais %}
            <div class="result-badge">
                {{ hospitais | length }} unidade{% if hospitais | length != 1 %}s{% endif %} encontrada{% if hospitais | length != 1 %}s{% endif %}
            </div>
            {% endif %}
        </div>

        <div class="row g-4">
            {% if hospitais %}
                {% for hospital in hospitais %}
                <div class="col-md-6 col-lg-4">
                    <div class="hospital-card h-100">
                        <div class="card-icon-wrap">
                            <span class="card-icon">🏥</span>
                        </div>
                        <div class="card-info">
                            <h5 class="hospital-name">{{ hospital.display_name.split(',')[0] }}</h5>
                            <p class="hospital-address">{{ hospital.display_name }}</p>
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="col-12">
                    <div class="empty-state">
                        <div class="empty-icon">🔍</div>
                        <h5>Nenhum hospital encontrado</h5>
                        <p>Tente ajustar sua localização ou ampliar o raio de busca.</p>
                    </div>
                </div>
            {% endif %}
        </div>

    </div>

    <footer class="site-footer">
        <p>Owl Convenial &mdash; Sistema de Convênio Médico &copy; 2026</p>
    </footer>

</div>

</body>
</html>
